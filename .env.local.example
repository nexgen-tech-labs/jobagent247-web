# ─── Supabase (Auth + Database + Storage) ───────────────────────────────────
NEXT_PUBLIC_SUPABASE_URL=https://<project-ref>.supabase.co
NEXT_PUBLIC_SUPABASE_ANON_KEY=
SUPABASE_SERVICE_ROLE_KEY=

# ─── Anthropic ───────────────────────────────────────────────────────────────
ANTHROPIC_API_KEY=

# ─── Upstash Redis (rate limiting) ───────────────────────────────────────────
# Phase 3 — add when wiring AI agents
UPSTASH_REDIS_REST_URL=
UPSTASH_REDIS_REST_TOKEN=

# ─── GCP (Cloud Run scraper) ─────────────────────────────────────────────────
# Phase 4 — add when deploying the Python scraper
GCP_CLOUD_RUN_URL=https://jobagent247-scraper-<hash>-nw.a.run.app
CLOUD_TASKS_HANDLER_TOKEN= # random secret shared between Next.js and Cloud Run

# ─── Stripe (payments) ───────────────────────────────────────────────────────
# Phase 5 — add when wiring billing
STRIPE_SECRET_KEY=
STRIPE_WEBHOOK_SECRET=
NEXT_PUBLIC_STRIPE_PUBLISHABLE_KEY=
STRIPE_PRO_PRICE_ID=
STRIPE_ACCELERATOR_PRICE_ID=

# ─── Sentry (error tracking) ─────────────────────────────────────────────────
# Phase 5 — add before production launch
SENTRY_DSN=
NEXT_PUBLIC_SENTRY_DSN=
